{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/assets/**",
          "/media/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "tareas-catalogo",
      "urls": [
        "https://adequate-education-production.up.railway.app/api/tareas/**"
      ],
      "cacheConfig": {
        "maxSize": 5,
        "maxAge": "7d",
        "timeout": "10s",
        "strategy": "freshness"
      }
    },
    {
      "name": "provincias",
      "urls": [
        "https://adequate-education-production.up.railway.app/api/provincias/**"
      ],
      "cacheConfig": {
        "maxSize": 5,
        "maxAge": "7d",
        "timeout": "10s",
        "strategy": "freshness"
      }
    },
    {
      "name": "api-datos-usuario",
      "urls": [
        "https://adequate-education-production.up.railway.app/api/empresas/**",
        "https://adequate-education-production.up.railway.app/api/clientes/**",
        "https://adequate-education-production.up.railway.app/api/presupuestos/**",
        "https://adequate-education-production.up.railway.app/api/user-tareas/**",
        "https://adequate-education-production.up.railway.app/api/calculadora-materiales/**"
      ],
      "cacheConfig": {
        "maxSize": 100,
        "maxAge": "12h",
        "timeout": "5s",
        "strategy": "freshness"
      }
    }
  ]
}
